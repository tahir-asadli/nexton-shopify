<!-- Hero -->
<hero-slider>
  <section class="bg-brand-cloud">
    <div class="container">
      <div class="splide hero-splide">
        <div class="splide__track">
          <div class="splide__list">
            {% for selected_collection in section.settings.collections %}
              {% assign prices = selected_collection.products | map: 'price_min' %}
              {% assign lowest_price = prices | sort | first %}
              <div class="splide__slide grid grid-cols-2 h-70 md:h-120 lg:h-150">
                <div class="relative flex items-center">
                  <div class="flex flex-col gap-2 md:gap-3 lg:gap-6">
                    <h4 class="text-brand-gray font-medium text-sm sm:text-md lg:text-xl">
                      Starting from: {{ lowest_price | money }}
                    </h4>
                    <h2 class="h1 leading-[1]">{{ selected_collection.title }}</h2>
                    <div class="button-container">
                      <a href="{{ selected_collection.url }}" class="button large shadow">
                        <span>Explore now</span>
                        <svg viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
                          <path d="M9.58335 17.5C13.9556 17.5 17.5 13.9556 17.5 9.58333C17.5 5.21108 13.9556 1.66667 9.58335 1.66667C5.2111 1.66667 1.66669 5.21108 1.66669 9.58333C1.66669 13.9556 5.2111 17.5 9.58335 17.5Z" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round" />
                          <path d="M18.3334 18.3333L16.6667 16.6667" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round" />
                        </svg>
                      </a>
                    </div>
                  </div>
                </div>
                <div class="relative">
                  {% if selected_collection.image %}
                    {{
                      selected_collection.image
                      | image_url: width: 300
                      | image_tag: class: 'absolute top-0 left-0 w-full h-full object-contain object-right'
                    }}
                  {% endif %}
                  {% comment %}
                    <img
                      src="assets/images/hero-4.png"
                      class="absolute top-0 left-0 w-full h-full object-contain object-right"
                      alt=""
                    >
                  {% endcomment %}
                </div>
              </div>
            {% endfor %}
          </div>
        </div>
        <ul class="splide__pagination absolute! bottom-3!"></ul>
      </div>
    </div>
  </section>
</hero-slider>
{% schema %}
{
  "name": "Hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero Image"
    },
    {
      "type": "collection_list",
      "id": "collections",
      "label": "Collections"
    }
  ],
  "blocks": [],
  "presets": [
    {
      "name": "Hero"
    }
  ]
}
{% endschema %}
