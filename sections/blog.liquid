{% comment %}
  This section is used in the blog template to render the blog page listing all
  articles within a blog.

  https://shopify.dev/docs/storefronts/themes/architecture/templates/blog
{% endcomment %}
<section>
  <div class="container mt-10">
    {% render 'breadcrumb' %}
    <h1 class="h2 mb-3">{{ blog.title }}</h1>
    <div>
      {% paginate blog.articles by 12 %}
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-2 md:gap-3 lg:gap-5">
          {% for article in blog.articles %}
            <div class="relative border border-brand-silver-400 rounded-2xl overflow-clip group">
              {%- if article.image %}
                <a href="{{ article.url }}">
                  <img
                    src="{{ article.image | image_url: width: 340, height: 300, crop: 'center' }}"
                    alt="Article image"
                    width="340"
                    height="300"
                  >
                </a>
              {% endif %}
              <div
                class="absolute inset-0 w-full h-full bg-black/40 opacity-0 group-hover:opacity-100 transition-all pointer-events-none"
              ></div>
              <div class="w-full flex flex-col gap-2 absolute -bottom-full transition-all group-hover:bottom-0 z-1 p-4 text-white">
                <h5>
                  <a href="{{ article.url }}">{{ article.title }}</a>
                </h5>
                {% if article.excerpt %}
                  <p class="text-sm">{{ article.excerpt | strip_html | truncatewords: 15 }}</p>
                {% endif %}
                {% assign date = article.published_at | time_tag: format: 'date' %}
                <p class="text-xs">{{ 'blog.article_metadata_html' | t: date: date, author: article.author }}</p>
              </div>
            </div>
            {% comment %}
              <div>
                {% if article.image %}
                  {{ article.image | image_url: width: 1000 | image_tag }}
                {% endif %}
                <h2>
                  {{ article.title | link_to: article.url }}
                </h2>
                {% assign date = article.published_at | time_tag: format: 'date' %}
                <p>{{ 'blog.article_metadata_html' | t: date: date, author: article.author }}</p>
                <p>{{ article.excerpt }}</p>
              </div>
            {% endcomment %}
          {% endfor %}
        </div>
        {%- if paginate.pages > 1 -%}
          <div class="pagination">
            {{- paginate | default_pagination -}}
          </div>
        {%- endif -%}
      {% endpaginate %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "t:general.blog",
  "settings": []
}
{% endschema %}
