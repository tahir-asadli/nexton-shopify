<!-- Footer -->
<footer>
  <div class="container">
    <div class="grid gap-4 sm:grid-cols-{{section.settings.mobile_column_count}} lg:grid-cols-{{section.settings.tablet_column_count}} xl:grid-cols-{{section.settings.column_count}} py-15">
      {% content_for 'blocks' %}
    </div>
  </div>
</footer>
{% schema %}
{
  "name": "t:general.footer",
  "settings": [
    {
      "type": "range",
      "id": "column_count",
      "label": "Column count",
      "min": 1,
      "max": 30,
      "default": 4
    },
    {
      "type": "range",
      "id": "tablet_column_count",
      "label": "Tablet column count",
      "min": 1,
      "max": 30,
      "default": 4
    },
    {
      "type": "range",
      "id": "mobile_column_count",
      "label": "Mobile column count",
      "min": 1,
      "max": 30,
      "default": 1
    }
  ],
  "blocks": [
    {
      "type": "column"
    }
  ]
}
{% endschema %}
