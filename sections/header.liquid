<!-- Header -->
{%- assign logo_alt = shop.brand.logo.alt | default: shop.name | escape -%}
<header class="border-b border-brand-silver">
  <div class="container relative bg-white z-1">
    <div class="flex gap-2 justify-center items-center h-16 sm:h-25">
      <div class="shrink-0 flex items-center">
        <a href="{{routes.root_url}}" class="inline-flex rounded-xl">
          {{ shop.brand.logo | image_url: width: 160 | image_tag: alt: logo_alt, class: 'hidden sm:block' }}
          {{ shop.brand.square_logo | image_url: width: 24 | image_tag: alt: logo_alt, class: 'block sm:hidden' }}
        </a>
      </div>
      <search-bar class="flex justify-center shrink grow-0 md:shrink-0 md:grow max-w-60 sm:max-w-full mx-auto sm:mx-0">
        <form class="flex justify-center relative md:w-100">
          <input type="text" class="search-input w-full" name="q" value="" placeholder="Search in products...">
          <span class="size-4 sm:size-5 text-brand-gray absolute left-4 sm:left-6 top-2.5 sm:top-4">
            {{- 'icons/search.svg' | inline_asset_content -}}
          </span>
          <button
            data-clear
            class="absolute right-3 top-2.5 size-4 sm:right-6 sm:top-4 border border-brand-gray text-brand-black sm:size-5 rounded-full flex justify-center items-center cursor-pointer"
            type="button"
          >
            &times;
          </button>
        </form>
      </search-bar>
      <div class="flex gap-1 items-center sm:ml-auto">
        <button class="open-mobile-menu button ghost rounded w-8 h-7 p-0 flex sm:hidden text-brand-gray">
          <span class="[&_svg]:w-8 [&_svg]:h-7">
            {{- 'icons/hamburger-menu.svg' | inline_asset_content -}}
          </span>
        </button>
        <a href="{{ routes.account_url }}" class="hidden sm:flex items-center justify-center p-2 rounded-xl">
          <span class="size-6 text-brand-gray">
            {{- 'icons/account.svg' | inline_asset_content -}}
          </span>
        </a>
        <cart-button>
          <button data-button class="hidden sm:flex items-center justify-center p-2 rounded-xl relative cursor-pointer">
            <em class="size-6 text-brand-gray">
              {{- 'icons/cart.svg' | inline_asset_content -}}
            </em>
            <span
              data-cart-count
              class="absolute -top-1 -right-1 bg-brand-blue size-5 flex justify-center items-center text-white rounded-full font-semibold empty:hidden text-xs"
              >1</span
            >
          </button>
        </cart-button>
      </div>
    </div>
  </div>
</header>

{% comment %}
  <header>
    <h2 class="header__title">
      {{ shop.name | link_to: routes.root_url }}
    </h2>

    <div class="header__menu">
      {% for link in section.settings.menu.links %}
        {{ link.title | link_to: link.url }}
      {% endfor %}
    </div>

    <div class="header__icons">
      {% if shop.customer_accounts_enabled %}
        <shopify-account menu="{{ section.settings.customer_account_menu }}">
          {{ 'icon-account.svg' | inline_asset_content }}
        </shopify-account>
      {% endif %}

      <a href="{{ routes.cart_url }}">
        {% if cart.item_count > 0 %}
          <sup>{{ cart.item_count }}</sup>
        {% endif %}

        {{ 'icon-cart.svg' | inline_asset_content }}
      </a>
    </div>
  </header>

  {% stylesheet %}
    header {
      height: 5rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    header a {
      position: relative;
      text-decoration: none;
      color: var(--color-foreground);
      display: flex;
      align-items: center;
      justify-content: center;
    }
    header a sup {
      position: absolute;
      left: 100%;
      overflow: hidden;
      max-width: var(--page-margin);
    }
    header svg {
      width: 2rem;
    }
    header .header__menu,
    header .header__icons {
      display: flex;
      gap: 1rem;
    }
  {% endstylesheet %}

  {% schema %}
  {
    "name": "t:general.header",
    "settings": [
      {
        "type": "link_list",
        "id": "menu",
        "label": "t:labels.menu"
      },
      {
        "type": "link_list",
        "id": "customer_account_menu",
        "label": "t:labels.customer_account_menu",
        "default": "customer-account-main-menu"
      }
    ]
  }
  {% endschema %}
{% endcomment %}
