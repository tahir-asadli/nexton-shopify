<!-- Header -->
{%- assign logo_alt = shop.brand.logo.alt | default: shop.name | escape -%}
<header class="border-b border-brand-silver">
  <div class="container relative bg-white z-1">
    <div class="flex gap-2 justify-center items-center h-16 sm:h-25">
      <div class="shrink-0 flex items-center">
        <a href="{{routes.root_url}}" class="inline-flex rounded-xl">
          {{ shop.brand.logo | image_url: width: 160 | image_tag: alt: logo_alt, class: 'hidden sm:block' }}
          {{ shop.brand.square_logo | image_url: width: 24 | image_tag: alt: logo_alt, class: 'block sm:hidden' }}
        </a>
      </div>
      <search-bar class="flex justify-center shrink grow-0 md:shrink-0 md:grow max-w-60 sm:max-w-full mx-auto sm:mx-0">
        <form action="{{ routes.search_url }}" class="flex justify-center relative md:w-100">
          <input type="hidden" name="type" value="product,page">
          <input type="hidden" name="options[unavailable_products]" value="hide">
          <input
            type="text"
            class="search-input w-full"
            name="q"
            value="{{ search.terms | escape }}"
            placeholder="Search in products..."
          >
          <span class="size-4 sm:size-5 text-brand-gray absolute left-4 sm:left-6 top-2.5 sm:top-4">
            {{- 'icons/search.svg' | inline_asset_content -}}
          </span>
          <button
            data-clear
            class="absolute right-3 top-2.5 size-4 sm:right-6 sm:top-4 border border-brand-gray text-brand-black sm:size-5 rounded-full flex justify-center items-center cursor-pointer"
            type="button"
          >
            &times;
          </button>
        </form>
      </search-bar>
      <div class="flex gap-1 items-center sm:ml-auto">
        <button class="open-mobile-menu button ghost rounded w-8 h-7 p-0 flex sm:hidden text-brand-gray">
          <span class="[&_svg]:w-8 [&_svg]:h-7">
            {{- 'icons/hamburger-menu.svg' | inline_asset_content -}}
          </span>
        </button>
        <a href="{{ routes.account_url }}" class="hidden sm:flex items-center justify-center p-2 rounded-xl">
          <span class="size-6 text-brand-gray">
            {{- 'icons/account.svg' | inline_asset_content -}}
          </span>
        </a>
        <cart-button>
          <button data-button class="hidden sm:flex items-center justify-center p-2 rounded-xl relative cursor-pointer">
            <em class="size-6 text-brand-gray">
              {{- 'icons/cart.svg' | inline_asset_content -}}
            </em>
            <span
              data-cart-count
              class="absolute -top-1 -right-1 bg-brand-blue size-5 flex justify-center items-center text-white rounded-full font-semibold empty:hidden text-xs"
            ></span>
          </button>
        </cart-button>
      </div>
    </div>
  </div>
</header>
<notification-bar style="display: none">
  <section class="py-2">
    <div class="container">
      <div class="py-2.5 px-3.5 text-base border in-[.success]:bg-green-50 in-[.success]:border-green-300 in-[.success]:text-green-900 in-[.error]:bg-rose-50 in-[.error]:border-rose-300 in-[.error]:text-rose-900 rounded-md flex items-center gap-2 flex-wrap">
        <svg
          stroke="currentColor"
          fill="currentColor"
          class="hidden in-[.success]:block"
          stroke-width="0"
          viewBox="0 0 24 24"
          height="20px"
          width="20px"
          xmlns="http://www.w3.org/2000/svg"
        >
          <path fill="none" d="M0 0h24v24H0V0z"></path><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm4.59-12.42L10 14.17l-2.59-2.58L6 13l4 4 8-8z"></path>
        </svg>
        <svg
          stroke="currentColor"
          fill="currentColor"
          class="hidden in-[.error]:block"
          stroke-width="0"
          viewBox="0 0 24 24"
          height="20px"
          width="20px"
          xmlns="http://www.w3.org/2000/svg"
        >
          <path fill="none" d="M0 0h24v24H0V0z"></path><path d="M11 15h2v2h-2zm0-8h2v6h-2zm.99-5C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8z"></path>
        </svg>
        <span data-message></span>
      </div>
    </div>
  </section>
</notification-bar>

{% assign copy_date = 'now' | date: '%Y' %}
{% assign copy_text = 'Nexton eCommerce. &copy; date' %}
<!-- Mobile Menu -->
<mobile-menu class="hidden in-[.mobile-menu-open]:block">
  <div class="flex items-center sm:hidden fixed top-0 left-0 w-[calc(100%-70px)] bg-white/50 backdrop-blur-3xl drop-shadow-2xl z-2 h-full">
    <div class="w-5/6 h-5/6 mx-auto flex flex-col">
      <div class="flex justify-center py-10">
        <a href="{{routes.root_url}}" class="inline-flex rounded-xl">
          {%- assign logo_alt = shop.brand.logo.alt | default: shop.name | escape -%}
          {{ shop.brand.logo | image_url: width: 160 | image_tag: alt: logo_alt }}
        </a>
      </div>
      <div class="flex flex-col grow">
        <ul class="flex flex-col justify-center items-center gap-2 px-10 py-20">
          {% for link in section.settings.mobile_menu.links %}
            <li>
              <a class="text-sm transition text-brand-gray hover:text-brand-black" href="{{ link.url }}">
                {{ link.title }}
              </a>
            </li>
          {% endfor %}
        </ul>
        <div class="mt-auto">
          <div>
            <div class="text-xs text-center">{{ copy_text | replace: 'date', copy_date }}</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</mobile-menu>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "link_list",
      "id": "header_menu",
      "label": "Header menu"
    },
    {
      "type": "link_list",
      "id": "mobile_menu",
      "label": "Mobile menu"
    }
  ]
}
{% endschema %}
{% comment %}
  <header>
    <h2 class="header__title">
      {{ shop.name | link_to: routes.root_url }}
    </h2>

    <div class="header__menu">
      {% for link in section.settings.menu.links %}
        {{ link.title | link_to: link.url }}
      {% endfor %}
    </div>

    <div class="header__icons">
      {% if shop.customer_accounts_enabled %}
        <shopify-account menu="{{ section.settings.customer_account_menu }}">
          {{ 'icon-account.svg' | inline_asset_content }}
        </shopify-account>
      {% endif %}

      <a href="{{ routes.cart_url }}">
        {% if cart.item_count > 0 %}
          <sup>{{ cart.item_count }}</sup>
        {% endif %}

        {{ 'icon-cart.svg' | inline_asset_content }}
      </a>
    </div>
  </header>

  {% stylesheet %}
    header {
      height: 5rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    header a {
      position: relative;
      text-decoration: none;
      color: var(--color-foreground);
      display: flex;
      align-items: center;
      justify-content: center;
    }
    header a sup {
      position: absolute;
      left: 100%;
      overflow: hidden;
      max-width: var(--page-margin);
    }
    header svg {
      width: 2rem;
    }
    header .header__menu,
    header .header__icons {
      display: flex;
      gap: 1rem;
    }
  {% endstylesheet %}

  {% schema %}
  {
    "name": "t:general.header",
    "settings": [
      {
        "type": "link_list",
        "id": "menu",
        "label": "t:labels.menu"
      },
      {
        "type": "link_list",
        "id": "customer_account_menu",
        "label": "t:labels.customer_account_menu",
        "default": "customer-account-main-menu"
      }
    ]
  }
  {% endschema %}
{% endcomment %}
