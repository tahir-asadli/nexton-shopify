<div class="container">
  <div class="flex flex-col sm:flex-row gap-4 justify-between items-center py-8">
    {% for block in section.blocks %}
      <div class="flex items-center [&_.copyright-text]:text-base">
        {% render block.type, block: block %}
      </div>
    {% endfor %}
  </div>
</div>

{% schema %}
{
  "name": "Footer Info",
  "settings": [],
  "blocks": [
