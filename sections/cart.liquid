{% comment %}
  This section is used in the cart template to render /cart page with an
  overview of the items in customer's cart.

  https://shopify.dev/docs/storefronts/themes/architecture/templates/cart
{% endcomment %}

<!-- Navigation -->
{% assign discount_perc = cart.total_discount | times: 100.0 | divided_by: cart.original_total_price | round %}
<div id="cart-section">
  <section>
    <div class="container mt-10">
      {% render 'breadcrumb' %}
      <h1 class="h2 mb-3">Cart</h1>
    </div>
  </section>

  <section class="mt-10">
    <div class="container">
      {% if cart.item_count > 0 %}
        <div class="grid lg:grid-cols-12 gap-10 mb-20">
          <div class="lg:col-span-7">
            <product-cart data-section-id="{{ section.id }}">
              {% if cart.items %}
                {% form 'cart', cart %}
                  <fieldset>
                    <div class="p-6 border border-brand-silver rounded-2xl">
                      <div class="flex flex-col gap-6">
                        {% for item in cart.items %}
                          <cart-item data-key="{{ item.key }}">
                            <div class="flex gap-6 relative">
                              <div class="flex w-24 h-27">
                                {% if item.image %}
                                  {{
                                    item.image
                                    | image_url: width: 150, height: 150
                                    | image_tag: class: 'w-full h-full object-contain'
                                  }}
                                {% endif %}
                              </div>
                              <div class="w-full">
                                <h3 class="font-semibold text-base pr-8">
                                  <a href="{{ item.url }}">{{- item.title }}</a>
                                </h3>
                                {% unless item.product.has_only_default_variant %}
                                  <div class="flex flex-col gap-1 text-sm">
                                    {% for option in item.options_with_values %}
                                      <div class="">
                                        <span>{{ option.name }}:</span>
                                        <span class="text-black/60">{{ option.value }}</span>
                                      </div>
                                    {% endfor %}
                                  </div>
                                {% endunless %}
                                <div class="flex justify-between items-center gap-2 mt-5">
                                  <quantity-input>
                                    <button type="button" data-minus>&minus;</button>
                                    <input
                                      data-quantity-input
                                      type="number"
                                      name="updates[]"
                                      min="{{ item.variant.quantity_rule.min }}"
                                      {% if item.variant.quantity_rule.max %}
                                        max="{{ item.variant.quantity_rule.max }}"
                                      {% endif %}
                                      value="{{ item.quantity }}"
                                    >
                                    <button type="button" data-plus>&plus;</button>
                                  </quantity-input>
                                  <div class="text-right">
                                    <div class="font-semibold">{{ item.final_price | money }}</div>
                                    {% if item.original_price != item.final_price %}
                                      {% if item.variant.compare_at_price > item.original_price %}
                                        <div class="text-sm text-brand-gray">
                                          <s>{{ item.variant.compare_at_price | money }}</s>
                                        </div>
                                      {% endif %}
                                    {% else %}
                                      {% if item.variant.compare_at_price > item.original_price %}
                                        <div class="text-sm text-brand-gray">
                                          <s>{{ item.variant.compare_at_price | money }}</s>
                                        </div>
                                      {% endif %}
                                    {% endif %}
                                  </div>
                                </div>
                              </div>
                              <button
                                type="button"
                                data-remove
                                class="absolute top-2 right-0 size-6 rounded-full flex justify-center items-center cursor-pointer"
                              >
                                <span class="size-4 pointer-events-none">
                                  {{ 'icons/bin.svg' | inline_asset_content }}
                                </span>
                              </button>
                            </div>
                          </cart-item>
                        {% endfor %}
                      </div>
                    </div>
                    <div class="flex justify-end my-4">
                      <button class="button" data-update-button>Update cart</button>
                    </div>
                  </fieldset>
                {% endform %}
              {% else %}
                <div class="py-6 text-center text-brand-gray">Cart is empty</div>
              {% endif %}
            </product-cart>
          </div>
          <div class="lg:col-span-5">
            <div class="p-6 border border-brand-silver rounded-2xl">
              <div class="flex flex-col gap-2 mb-6">
                <div class="flex justify-between gap-6">
                  <div class="text-brand-gray">Subtotal</div>
                  <div class="text-brand-gray font-semibold">{{ cart.items_subtotal_price | money }}</div>
                </div>
                {% if cart.total_discount > 0 %}
                  <div class="flex justify-between gap-6">
                    <div class="text-brand-gray">Discount</div>

                    <div class="text-brand-gray font-semibold">
                      (-{{ discount_perc }}) {{ cart.total_discount | money }}
                    </div>
                  </div>
                {% endif %}
              </div>
              <div class="mb-6">
                <div class="flex justify-between gap-6">
                  <div class="font-semibold">Total</div>
                  <div class="font-semibold">{{ cart.total_price | money_with_currency }}</div>
                </div>
              </div>
              <discount-form>
                <form class="flex flex-col mb-6 " method="post" action="{{routes.cart_update_url}}">
                  <div class="flex gap-6 relative">
                    <input type="text" name="discount" class="text-input w-full py-3.5" placeholder="Add promo code">
                    <button class="button medium rounded-lg py-3 absolute top-1 right-1 text-sm cloud">Apply</button>
                  </div>
                  <div><small class="text-brand-gray-400 my-1"> (Example: 25PC)</small></div>
                </form>
              </discount-form>
              <div>
                <a href="/checkout" class="button medium w-full">Go to Checkout</a>
              </div>
            </div>
          </div>
        </div>
      {% else %}
        <div class="py-4 text-center">
          <p>Your cart is currently empty.</p>
        </div>
      {% endif %}
    </div>
  </section>
</div>

{% schema %}
{
  "name": "t:general.cart",
  "settings": []
}
{% endschema %}
