{%- unless template == 'index' or template == '404' -%}
  {%- assign t = template | split: '.' | first -%}
  <!-- Breadcrumb -->
  <div class="flex items-center gap-3 mb-4">
    <a class="text-brand-gray-600" href="{{ routes.root_url }}">Home</a>
    <span class="text-gray-300 text-xs">/</span>
    {%- case t -%}
      {%- when 'page' -%}
        <a href="{{ page.url }}" class="text-brand-gray-400">{{ page.title }}</a>
      {%- when 'product' -%}
        {% assign first_collection = product.collections | first %}
        {%- if first_collection.url -%}
          <a href="{{ first_collection.url }}" class="text-brand-gray-600">{{ first_collection.title }}</a>
          <span class="text-gray-300 text-xs">/</span>
        {%- endif -%}
        <span class="text-gray-500">{{ product.title }}</span>
      {%- when 'collection' and collection.handle -%}
        {%- if current_tags -%}
          <a href="{{ collection.url }}" class="text-brand-gray-400">{{ collection.title }}</a>
          <span class="text-gray-300 text-xs">/</span>
          {%- capture tag_url -%}{{ collection.url }}/{{ current_tags | join: "+"}}{%- endcapture -%}
          <a href="{{ tag_url }}" class="text-brand-gray-400">{{ current_tags | join: ' + ' }}</a>
        {%- else -%}
          <a class="text-brand-gray-600" href="{{ routes.collections_url }}">Collections</a>
          <span class="text-gray-300 text-xs">/</span>
          <span class="text-gray-500">{{ collection.title }}</span>
        {%- endif -%}
      {%- when 'blog' -%}
        {%- if current_tags -%}
          <a href="{{ blog.url }}" class="text-gray-500">{{ blog.title }}</a>
          <span class="text-gray-300 text-xs">/</span>
          {%- capture tag_url -%}{{blog.url}}/tagged/{{ current_tags | join: "+" }}{%- endcapture -%}
          <a href="{{ tag_url }}" class="text-brand-gray-600">{{ current_tags | join: ' + ' }}</a>
        {%- else -%}
          <a href="{{ blog.url }}" class="text-brand-gray-600">{{ blog.title }}</a>
        {%- endif -%}
      {%- when 'article' -%}
        <a href="{{ blog.url }}" class="text-brand-gray-600">{{ blog.title }}</a>
        <span class="text-gray-300 text-xs">/</span>
        <span href="{{ article.url }}" class="text-gray-500">{{ article.title }}</span>
      {%- else -%}
        <span href="{{ request.path }}" class="text-gray-500">{{ page_title }}</span>
    {%- endcase -%}
  </div>
{%- endunless -%}
