<product-dialog>
  <dialog class="rounded-2xl p-6 border border-gray-300" closedby="any">
    <div class="dialog-content-container">
      <div class="dialog-content empty:hidden"></div>
      <div class="dialog-message min-w-150 min-h-50 flex justify-center items-center empty:hidden">Loading</div>
    </div>
    <button
      id="close-dialog"
      class="absolute top-4 right-4 text-2xl p-2 bg-gray-200 cursor-pointer w-10 h-10 flex items-center justify-center rounded-full"
    >
      &times;
    </button>
  </dialog>
</product-dialog>
